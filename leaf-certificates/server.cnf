[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
req_extensions     = req_ext

[ dn ]
C  = MA
ST = Tanger-Tetouan-Al Hoceima
L  = Tanger
O  = Master MMSD
OU = Cryptography and Blockchain
CN = www.mmsd-pki.local

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
DNS.1 = www.mmsd-pki.local
DNS.2 = mmsd-pki.local
IP.1  = 127.0.0.1
